# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database (TimescaleDB / PostgreSQL) ───────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akilli_tarim
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akilli_tarim

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Celery uses a separate DB index to avoid key collisions with Django cache
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MQTT (Mosquitto) ──────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# Credentials for the backend service (farm-wide read/write access)
MQTT_BACKEND_USERNAME=backend
MQTT_BACKEND_PASSWORD=change-me-backend-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ── Weather (Open-Meteo) ──────────────────────────────────────────────────────
# Open-Meteo is free and requires no API key.
# Set cache TTL in seconds (default: 3600 = 1 hour, per NFR-05)
WEATHER_CACHE_TTL_SECONDS=3600

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=change-me-smtp-password
DEFAULT_FROM_EMAIL=Akıllı Tarım <noreply@example.com>

# ── Export storage ────────────────────────────────────────────────────────────
# Local directory (inside the container) where async export files are saved
EXPORT_ROOT=/app/exports
# Sync/async threshold: requests with more than this many rows go through Celery
EXPORT_SYNC_ROW_THRESHOLD=10000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
